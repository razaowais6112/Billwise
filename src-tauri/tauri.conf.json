{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Billwise",
  "version": "0.1.0",
  "identifier": "com.billwise.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Billwise",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/assets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": "all",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
